# ── PostgreSQL ──
# Khi dùng Docker Compose: hostname là "postgres" (tên service)
DATABASE_URL=postgresql://aquaguard:aquaguard_pass@postgres:5432/aquaguard_db

# ── JWT ──
JWT_SECRET=aquaguard_jwt_secret_2026

# ── Redis (live-location hot store) ──
# Local Docker Compose sets this automatically to redis://redis:6379.
# Production: an Upstash connection string, e.g. rediss://default:<token>@<host>:6379
# Leave empty to disable Redis — live tracking then falls back to PostgreSQL.
REDIS_URL=redis://redis:6379

# ── Server ──
PORT=5001

# ── Cloudinary (Image Upload) ──
# Lấy URL tại: https://cloudinary.com → Dashboard → CLOUDINARY_URL
CLOUDINARY_URL=

# ── Twilio Verify (SMS OTP) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Resend (Email) ──
# Lấy API key tại: https://resend.com → API Keys
RESEND_API_KEY=
# Địa chỉ gửi đi. Chưa verify domain thì để mặc định bên dưới (gửi thử được ngay).
# Sau khi verify domain riêng ở Resend, đổi thành: AquaGuard <no-reply@your-domain.com>
EMAIL_FROM=AquaGuard <no-reply@aquaguard.vn>

# ── TURN (WebRTC voice/video call relay) ──
# Cần cho cuộc gọi chạy ổn định trên mạng 4G/NAT đối xứng. Không cấu hình thì
# vẫn có STUN công cộng (đủ để test cùng LAN / NAT thường). Chọn MỘT trong hai:
#
# 1) Cloudflare TURN — server tự mint credential ngắn hạn (khuyến nghị, free tier rộng):
#    Tạo tại https://dash.cloudflare.com → Calls → TURN
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=
#
# 2) Hoặc TURN tĩnh (vd Metered https://www.metered.ca/tools/openrelay):
#    TURN_URLS nhiều URL ngăn cách bằng dấu phẩy.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
