Citizen "1" -- "0..*" RescueRequest : submits >

' ── R5: Association — Rescuer handles RescueRequest ──
Rescuer "0..1" -- "0..*" RescueRequest : handles >

' ── R6: Association — Admin assigns rescuer to RescueRequest ──
Admin "0..1" -- "0..*" RescueRequest : assigns rescuer to >

' ── R7: Association — Rescuer creates RescueGroup ──
Rescuer "1" -- "0..*" RescueGroup : creates >

' ── R8: Association — Rescuer leads RescueGroup ──
Rescuer "1" -- "0..1" RescueGroup : leads >

' ── R9: Composition — RescueRequest *-- RescueRequestLog ──
RescueRequest "1" *-- "0..*" RescueRequestLog : contains >

' ── R10: Composition — RescueGroup *-- RescueGroupMember ──
RescueGroup "1" *-- "0..*" RescueGroupMember : contains >

' ── R11: Composition — RescueGroup *-- RescueGroupInvite ──
RescueGroup "1" *-- "0..*" RescueGroupInvite : contains >

' ── R12: Aggregation — User o-- Notification ──
User "1" o-- "0..*" Notification : receives >

' ── R13: Aggregation — RescueGroup o-- RescueRequest ──
