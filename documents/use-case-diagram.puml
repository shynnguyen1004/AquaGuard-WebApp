@startuml AquaGuard_UseCase_Diagram

' ============================================================
'  AquaGuard — Flood Alert & Rescue Web Platform
'  UML Use Case Diagram (PlantUML)
'  Version: 1.0 | Date: 2026-04-15
'  18 Use Cases | 5 Actors | 36 Relationships
' ============================================================

left to right direction
skinparam actorStyle awesome
skinparam usecaseFontSize 11
skinparam actorFontSize 12
skinparam usecaseBackgroundColor #E8EAF6
skinparam usecaseBorderColor #3949AB
skinparam rectangleBackgroundColor #FAFAFA
skinparam rectangleBorderColor #1E3A8A
skinparam arrowColor #37474F
skinparam stereotypeFontSize 10

' ============================
'  ACTORS — PRIMARY (LEFT)
' ============================

actor "Citizen" as CITIZEN #d1fae5;line:10b981
actor "Rescuer" as RESCUER #fef3c7;line:f59e0b
actor "Admin" as ADMIN #fee2e2;line:ef4444

' Abstract parent actor
actor "User" as USER <<abstract>>

' ============================
'  ACTORS — SECONDARY (RIGHT)
' ============================

actor "Twilio SMS\nGateway" as TWILIO #e0e7ff;line:6366f1
actor "Groq AI\nService" as GROQ #e0e7ff;line:6366f1

' ============================
'  ACTOR GENERALISATION
'  (hollow triangles TO parent)
' ============================

CITIZEN --|> USER
RESCUER --|> USER
ADMIN --|> USER

' ============================
'  SYSTEM BOUNDARY
' ============================

rectangle "AquaGuard — Flood Alert & Rescue System" {

  ' ── Authentication & Profile ──
  usecase "Register Account" as UC01
  usecase "Login to System" as UC02
  usecase "Reset Password" as UC03
  usecase "Verify Phone OTP" as UC03a
  usecase "Update Profile" as UC04

  ' ── SOS & Rescue ──
  usecase "Submit SOS Request" as UC05
  usecase "Track Rescue Status" as UC06
  usecase "View Pending\nRequests" as UC07
  usecase "Accept Rescue\nMission" as UC08
  usecase "Complete Rescue\nMission" as UC09
  usecase "Cancel Rescue\nMission" as UC08x

  ' ── Group & Family ──
  usecase "Manage Rescue\nGroup" as UC10
  usecase "Manage Family\nConnection" as UC11
  usecase "Track Family\nSafety" as UC12

  ' ── Map & Zones ──
  usecase "View Flood Map" as UC13
  usecase "Manage Flood\nZones" as UC14

  ' ── Admin Management ──
  usecase "Manage Users" as UC15
  usecase "Assign Rescuer\nto SOS" as UC16
  usecase "Force Complete\nRequest" as UC16x
  usecase "View System\nAnalytics" as UC17

  ' ── Chatbot ──
  usecase "Ask Chatbot" as UC18
}

' ============================
'  ASSOCIATIONS — Citizen
' ============================

CITIZEN --> UC01
CITIZEN --> UC02
CITIZEN --> UC05
CITIZEN --> UC06
CITIZEN --> UC11
CITIZEN --> UC12
CITIZEN --> UC13
CITIZEN --> UC18

' ============================
'  ASSOCIATIONS — Rescuer
' ============================

RESCUER --> UC02
RESCUER --> UC07
RESCUER --> UC08
RESCUER --> UC09
RESCUER --> UC10
RESCUER --> UC13

' ============================
'  ASSOCIATIONS — Admin
' ============================

ADMIN --> UC02
ADMIN --> UC14
ADMIN --> UC15
ADMIN --> UC16
ADMIN --> UC17

' ============================
'  ASSOCIATIONS — Shared (via User generalisation)
' ============================

USER --> UC03
USER --> UC04

' ============================
'  ASSOCIATIONS — Secondary Actors (RIGHT)
' ============================

UC03a --> TWILIO
UC18 --> GROQ

' ============================
'  <<include>> RELATIONSHIPS
'  (dashed arrow FROM base TO included)
' ============================

UC05 ..> UC02 : <<include>>
UC08 ..> UC07 : <<include>>
UC16 ..> UC07 : <<include>>
UC03 ..> UC03a : <<include>>

' ============================
'  <<extend>> RELATIONSHIPS
'  (dashed arrow FROM extending TO base)
' ============================

UC06 ..> UC05 : <<extend>>\n{if SOS accepted}
UC09 ..> UC08 : <<extend>>\n{if rescue successful}
UC08x ..> UC08 : <<extend>>\n{if cannot reach victim}
UC16x ..> UC16 : <<extend>>\n{if admin overrides}

@enduml
