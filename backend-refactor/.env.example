# ── PostgreSQL ──
# Khi dùng Docker Compose: hostname là "postgres" (tên service)
DATABASE_URL=postgresql://aquaguard:aquaguard_pass@postgres:5432/aquaguard_db

# ── JWT ──
JWT_SECRET=aquaguard_jwt_secret_2026
JWT_EXPIRES_IN=7d
SALT_ROUNDS=10

# ── Role gate (cho đăng ký admin/rescuer) ──
ROLE_PASSWORD=123456

# ── Server ──
PORT=5001
NODE_ENV=development
FRONTEND_URL=

# ── Cloudinary (Image Upload) ──
CLOUDINARY_URL=

# ── Twilio Verify (SMS OTP) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
